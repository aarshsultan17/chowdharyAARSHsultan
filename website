                    <p class="year">2023 • Short Film</p>
                </div>
            </div>
            <!-- Add more work cards as needed -->
        </div>
    </section>

    <!-- Skills & Training -->
    <section id="skills">
        <h2 class="section-title">Skills & Training</h2>
        <div class="skills-grid">
            <div class="skill-card">
                <div class="skill-icon">🎭</div>
