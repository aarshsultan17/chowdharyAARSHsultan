                <p>Contemporary dance, stage combat, choreography</p>
            </div>
            <div class="skill-card">
                <div class="skill-icon">🎬</div>
                <h4>On-Camera</h4>
                <p>Film acting, audition technique, self-taping</p>
            </div>
        </div>
