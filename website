            </div>
            <div class="gallery-item">
                <img src="mood-shot-3.jpg" alt="Mood shot">
            </div>
            <div class="gallery-item">
                <img src="mood-shot-4.jpg" alt="Mood shot">
            </div>
            <div class="gallery-item">
                <img src="mood-shot-5.jpg" alt="Mood shot">
            </div>
            <div class="gallery-item">
                <img src="mood-shot-6.jpg" alt="Mood shot">
            </div>
        </div>
    </section>

    <!-- Work / Filmography -->
    <section id="work">
        <h2 class="section-title" style="color: white;">My Work</h2>
        <div class="work-grid">
            <div class="work-card">
                <img src="project-1.jpg" alt="Project thumbnail">
                <div class="work-info">
                    <h4>Project Title</h4>
                    <p class="role">Lead Role - Character Name</p>
                    <p class="year">2024 • Feature Film</p>
                </div>
            </div>
            <div class="work-card">
                <img src="project-2.jpg" alt="Project thumbnail">
                <div class="work-info">
                    <h4>Project Title</h4>
