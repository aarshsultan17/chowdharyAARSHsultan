                    <p class="institution">University Name</p>
                    <p>Bachelor's Degree in Performing Arts</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section id="contact">
        <h2 class="section-title" style="color: white;">Get In Touch</h2>
        <p style="max-width: 600px; margin: 0 auto; color: #aaa;">
            Available for auditions, collaborations, and new projects. 
            Let's create something amazing together.
        </p>
        <div class="contact-info">
            <div class="contact-item">
                <h4>Email</h4>
                <a href="mailto:your@email.com">your@email.com</a>
            </div>
            <div class="contact-item">
                <h4>Phone</h4>
